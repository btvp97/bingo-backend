# Copy this file to .env and fill in real values. Never commit .env.

# Connection string for your Postgres database. Free hosted options that work
# fine for this scale: Neon, Supabase, or Railway. Local Postgres via Docker
# or Postgres.app also works.
DATABASE_URL="postgresql://user:password@localhost:5432/bingo?schema=public"

# Any long random string — used to sign player session tokens (JWTs).
# Generate one with: openssl rand -hex 32
JWT_SECRET="change-me-to-a-long-random-string"

# Any long random string — used to authorize the /admin/* endpoints (board and
# team creation). Only you should know this.
ADMIN_SECRET="change-me-too"

PORT=4000
